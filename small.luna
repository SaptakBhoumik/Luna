// ---- Error handling ----
fn divide(a:f64, b:f64) -> !f64 {
    //THe : signifies if block without any else if and stuff i.e npt a match statement
    when b == 0.0:{ ret Error("div by zero") } //Note:-Error is just a struct with string field. Nothing fancy. Error is a builtin type and is meant specifically 
                                            //for error handling. The Error struct has an implicit field called msg which is the error message. You can access it using err.msg in the !! block. 
                                            // You can not create your own error types
    //Note:For when statement, u can just do ``when cond {.....}``
    //But if else if is needed then u do 
    //``when {
    //    cond1:{....}
    //    cond2:{....}
    //    ?:{....} // else case. ? is used for else case in if else if ladder. It is optional but good for readability
    //}``

    (a,b) += (1.0,1.0) //Yes you can do tuple assignment like this. It is basically the same as a=a+1.0 and b=b+1.0
    ret a / b
}
fn safe_open(path:str) -> !i32 {
    ret fs::open(path)!
}
fn find_val(arr:[i32,5], idx:i32) -> ?i32 {
    when (idx < 0 | idx >= 5):{ ret None }
    ret arr[idx]
}

// ---- Defer ----
fn read_file(path:str) -> !str {
    f := fs::open(path)!
    defer { fs::close(f) }
    //Note:-You dont need to enclose it in ```{...}``` if only one statement so something like the following also works
    defer fs::close(f)
    ret fs::read(f)!
}

// ---- Drop ordering ----
fn drop_demo() -> !void {
    a := Buf(fd = fs::open("a.txt")!)  // dropped second
    b := Buf(fd = fs::open("b.txt")!)  // dropped first
}

// ---- Threading ----
fn fetch(url:str) -> !str {
    resp := http::get(url)!
    ret resp.body
}

mut hit_count:atomic{i32} = 0
thread_local mut tid:i32 = 0
thread_local mut (T1,T2) := (0,0)//yes u can do with tuple also
fn counter_demo() -> i32 {
    mut count:atomic{i32} = 0
    mut handles:[Thread{void},4] = []//The generic parameter of Thread is the return type of the thread function
    loop mut i :0..4 {
        handles[i] = thread { loop _ :0..100 { count++ } }
    }
    loop mut t :handles { t.join()! }
    ret count
}

fn complex_tuple_type{T}(val:T) -> (T[1],T[0]){
    (A,mut B) := (val[1], val[0])
    ret A,B
}
fn complex_tuple_type(val:((i32,i32),i32)) -> ((i32,i32),i32){
    ((a,b),c) := val
    ret ((a,b),c)
}
((a,pub mut b),pub c) := complex_tuple_type(((1,2),3)) 
pub mut A,B := a,b

fn lock_demo() -> !void {
    mut bal:atomic{i32} = 100
    mut old_bal:i32 = 100
    t1 := thread { lock bal { bal = bal - 10 } }
    t2 := thread { 
        lock (bal,old_bal) { //The bracket is needed to signify that it is a tuple of variables and not just a single variable.
            old_bal = bal
            bal = bal + 20 
        } 
        lock {
            //This is also valid syntax. Locks every variable used in this block
        }
    }
    t1.join()!
    t2.join()!
    io::println(f"bal:{bal}")
}
CONST1:=10.2E-3
CONST2:!i32 = Error("not initialized")//Yes this is actually valid. Btw you can also have *!T but idk why you will need it. But u can just for consistancy
fn chan_demo() -> !void {
    ch:Chan{i32} = Chan{i32}(cap = 4)
    p := thread { 
        loop i :0..4 { 
            ch.send(i) 
        } 
        ch.close() 
    }
    c := thread { 
        loop {
            v := ch.recv() ?? { break }
            io::println(v) 
        } 
    }
    p.join()!
    c.join()!
}


fn task_chan_demo() -> !void {
    //Basically same as thread but for concurrent task
    ch:TaskChan{i32} = TaskChan{i32}(cap = 4)
    task_local mut local_var:i32 = 0//This variable is local to each task. Each task will have its own copy of this variable. It is not shared between tasks. 
    p : Task{Void} = task(restart_count = 100, timeout = 1000) { 
        //Time out is in ms. If task is running for more than 1000ms then it will be killed and restarted. Note if we have no restart then we just kill the thread on time out
        //And timeout duration is calculated fresh from each restart
        //Restart 100 times if task panics. If it panics over 100 times then throw error. No need to wait between failed task
        //Note:-We keep restarting and not just restart at join i.e restart before join if panics
        loop i :0..4 { 
            ch.send(i) 
            local_var += i
        } 
        ch.close() 
    }
    c := task(always_restart = True,restart_delay = 100) { 
        //This task will always restart if it panics. No need to specify restart count because it will always restart. 
        //But we can specify restart delay if we want to wait between failed tasks
        loop {
            v := ch.recv() ?? { break }
            io::println(v) 
        } 
    }
    //Note:The restart and timeout syntax also works for threads as well
    //We also have task_local like thread_local and does the thing you expect it does. No seperate task_atomic cuz doesnt make sense if you thing about it.
    p.join()!
    c.join(timeout = 100)!//In ms
    //If timeout happens then we will just cancel the task and clean up the resources(But what if an extern C function cancels or creates unjoined threads. Rare case but think about it. Maybe some sort of attribute)
    //We also have a dedicated .cancel method thread also has it
}
fn select_demo() -> !void {
    ch1:Chan{i32} = Chan{i32}(cap = 4)
    ch2:Chan{str} = Chan{str}(cap = 4)
    t := timer::after(500)   // Sends a signal after 500ms. Simple but works
    task {
        select {
            // select for waiting on multiple channels and using the one that is ready first.
            v <-- ch1:{ 
                io::println(f"got {v}") 
                break
            }
            42 --> ch2:{ 
                io::println("sent") 
                break
            }
            ?:{ io::println("neither ready") }
        }
    }
    task {
        select {
            //Note if multiple cases are ready then the first one in the code will be executed then the next one from code that was ready during select and on.
            // So even if a channel get's ready while the other is running but it was not ready when select started then it will not be executed in the current select and will have to wait for the next select. 
            //Use break to avoid that if needed.
            //Btw when 2 cases share the same body(like 5 <-- ch1 and 42 <-- ch1) then if any of them is ready then the body will be executed 
            //and the other case will be skipped even if it is ready(Not choosen randomly. Based on order in code). So in that case also only one case will be executed and not both.
            5    <-- ch1//No : after ch1 because we want to execute the same code for both 5 and 42. So if ch1 is 5 or 42 then we will execute the same code.
            42   <-- ch1:{ io::println("got 42 or 5") }
            0    <-- ch1:{ io::println("got zero") }
            v    <-- ch1:{ io::println(f"got {v}") }  // catch-all
            //If ch1 is not ready then we skip it. If ch1 is ready then we do if else basically. So if ch1 is 42 then we execute the first case and skip the next 2 cases. 
            //If ch1 is 0 then we skip the first case and execute the second case and skip the third case. If ch1 is some other value then we skip the first 2 cases and 
            //execute the third case.
            42 --> ch2:{ io::println("sent") }
            _  <-- t:{ io::println("timed out") }
        }
    }
}
// ---- Attributes ----. TODO:Other attributes in future like [unjoined_thread](For saying this function has unjoined threads. Useful for C function where the function is opaque) and more
@[inline] fn fast_add(a:i32, b:i32) -> i32 { ret a+b }
@[noinline] fn slow_mul(a:i32, b:i32) -> i32 { ret a*b }

@[deprecated(msg = "use divide()", after = "2025-01-01")]
fn old_div(a:f64, b:f64) -> f64 { ret a/b }

@[extern("c_puts")]//Note:-You cant put pub on extern functions as they are c functions and not part of this module's public API. They are just linked in from external libraries.
fn c_puts(ptr:*i32) -> i32

@[inline]
@[noreturn]
fn die(msg:str) { std::exit(1) }

@[export("luna_add")]
pub fn add(a:i32, b:i32) -> i32 { ret a+b }

@[align(64)] mut cache_buf:[u8,64] = []

// ---- Variadic ----
fn sum_all(*args:i32) -> i32 {
    mut t := 0
    $loop $v : args { t += $v }
    ret t
}
@[extern("printf")]
fn c_printf(...) -> i32
//If a extern function takes in a lambda then during codegen the function passed to the extern function must be wraped in a lambda even if it is already a lambda.
//This is because the extern function expects a C function pointer and not a Luna function pointer(Which passes by reference somethimes), and the lambda wrapper 
//will have the correct calling convention for C. Done by compiler and not a progammer, but good to know for understanding the generated code.
// ---- Decorators ----
fn logged(f:fn(i32)->i32) -> fn(i32)->i32 {
    ret fn(x:i32)[=] -> i32 {
        io::println(f"in:{x}")
        r := f(x)
        io::println(f"out:{r}")
        ret r
    }
}
fn repeat(n:i32, f:fn(i32)->i32) -> fn(i32)->i32 {
    ret fn(x:i32)[n,f] -> i32 {
        mut r := x
        mut i := 0
        loop i < n { r=f(r)
            i++
        }
        ret r
    }
}
@logged
fn triple(x:i32) -> i32 { ret x*3 }
@repeat(2)
fn inc_twice(x:i32) -> i32 { ret x+1 }

// ---- Generics ----
fn max{T}(a:T, b:T) -> T { ret a>b ? a :b }
fn min{T}(a:T, b:T) -> T { ret a<b ? a :b }
fn clamp{T}(v:T, lo:T, hi:T) -> T { ret max{T}(lo, min{T}(v,hi)) }
fn clamp(v:i8, lo:i8, hi:i8) -> i8 { ret 0 } // non-generic overload

// ---- Regular functions ----
fn fact(n:i32) -> i32 { ret n<=1 ? 1 :n*fact(n-1) }
fn fib(n:i32) -> i32 {
    when {
        n<=1:{ ret n }
    }
    ret fib(n-1)+fib(n-2)
}
fn is_prime(n:i32) -> bool {
    when {
        n<2:{ ret False }
    }
    mut i := 2
    loop i*i <= n { 
        when {
            n%i==0:{ ret False }
        }
        i++ 
    }
    ret True
}
fn double(x:i32) -> i32 { ret x*2 }
fn inc(x:i32) -> i32 { ret x+1 }
fn square(x:i32) -> i32 { ret x*x }
fn minmax(a:i32, b:i32) -> (i32,i32) { ret a<b ? (a,b) :(b,a) }
fn greet(name:str, msg:str = "Hi") -> str { ret f"{msg} {name}" }

fn sizeof{T}(val:T) -> u64 {
    ret $typesize{T}()
}
