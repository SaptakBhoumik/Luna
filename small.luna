fn python_style_variadic($regular_arg:i8,*args,**kwarg){//Yes even in non compile time function we can have compile time argument
    //Note:-Not a compile time function
    $loop $arg : args{
        $when{
            kwarg.$contains("decay"):{
                io::println($arg*kwarg["decay"])
            }
            ?:{
                io::println($arg)
            }
        }
    }
}

