}
// ---- Forward declarations ----
type Node
fn is_odd(n:i32) -> bool
fn (p:Point)len() -> f64

type Node = {
    pub val:i32
    pub mut next:*Node
}
fn is_odd(n:i32) -> bool { ret n % 2 != 0 }
fn (p:Point)len() -> f64 { ret math::sqrt(p.x*p.x + p.y*p.y) }
// Regarding structs. When u do something like Point(1,0) then it acts like a function call and will create a Point struct. So yes, if you want u can pass it like
// A lambda function. That means a struct is just a function that returns a struct. 
// ---- Methods ----
//Magic methods for operator overloading and indexing
fn (p:Point)__add__(o:Point) -> Point { ret Point(x = p.x+o.x, y = p.y+o.y) }
fn (p:Point)__eq__(o:Point) -> bool { ret p.x==o.x & p.y==o.y }
fn (p:Point)__ne__(o:Point) -> bool { ret !(p==o) }
fn (s:Stack{T})__getitem__{T}(i:i32) -> T{ ret s.data[i] }
fn (mut s:Stack{T})__setitem__{T}(i:i32, val:T){ s.data[i]=val }

fn (mut s:Stack{T})push{T}(val:T)//Unlike go, you have to specify the generic type parameter on methods as well, but you can omit it at call site as it can be inferred from the argument.
{ 
    {
        //Scope
        a:="hello"
    }
    //a is not accessible here. 
    s.data[s.top]=val
    s.top++ 
}
fn (mut s:Stack{T})pop{T}() -> T{ s.top--
    ret s.data[s.top]
}
fn (s:Stack{T})is_empty{T}() -> bool  { ret s.top==0 }

// ---- Constants ----
PI:f64 = 3.14159265358979

// ---- Overloaded functions ----
fn area(c:Circle) -> f64 { ret PI * c.r * c.r }
fn area(r:Rect) -> f64 {
    ret (r.br.x - r.tl.x) * (r.br.y - r.tl.y)
}

