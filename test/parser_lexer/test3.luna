fn func5(){
    mut bal:atomic<i32> = 100
    mut old_bal:i32 = 100
    t1 := thread { lock bal { bal = bal - 10 } }
    t2 := thread { 
        lock (bal,old_bal) { 
            old_bal = bal
            bal = bal + 20 
        } 
        lock bal,old_bal {} 
        lock {
            //This is also valid syntax. Locks every variable used in this block
        }
    }
}