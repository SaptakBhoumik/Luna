fn func1(){
    defer {
        print("deferred")
    }
    defer print("deferred 2")
    defer {print("deferred 3")}
    defer {print("deferred 4")
    }
    {}
    {

    }
    {
        print("hello")
    }
    {print("hello 2")
    }
    {print("hello 3")}

    loop {
        break
    }
    loop {
        continue
    }
    ret
}

