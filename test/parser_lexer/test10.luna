b := fn()->i32{
    ret 10
}
b := fn(){}
b := fn()[]{}
b := fn()[]->i32{
    ret 20
}

b := fn(a:i8)->i32{
    ret a.b->c
}
b := fn(a:i8){}
b := fn(a:i8)[]{}
b := fn(a:i8)[]->i32{
    ret 20
}


b := fn(a:i8)[&]{}
b := fn(a:i8)[=]{}
b := fn(a:i8)[&a,b]{}
b := fn(a:i8)[&a]{}

func()
func(a,b)
func(a,b=10)
func(a,b=10, c=20)
func(a,b=10, $c=20)
$(1+$a)

f"{1+2}"
f" aas {1+2}"
f"{1+2} faas"
f"{1+2} {faas}"
f"{1+2}{faas}"
f"{1+2}a{faas}"
f"a{1+2}a{faas}"
f"a{1+2}a{faas}a"

_test => {}
_test => [&]{}
_test() => fn(a:i8)->i8{}
_test(123) => fn(a:i8)[=]->i8{}


